<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.SearchController">
    <center>
        <VBox spacing="12">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <children>
                <Label text="Photo Search" />
                <Label fx:id="messageLabel" text="Search photos" />
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <RadioButton fx:id="dateModeRadio" text="Date Range" />
                        <RadioButton fx:id="tagModeRadio" text="Tag Search" />
                    </children>
                </HBox>
                <VBox fx:id="dateSearchBox" spacing="10">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="Start Date:" />
                                <DatePicker fx:id="startDatePicker" />
                                <Label text="End Date:" />
                                <DatePicker fx:id="endDatePicker" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox fx:id="tagSearchBox" spacing="10">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="Tag Mode:" />
                                <ComboBox fx:id="tagQueryModeComboBox" prefWidth="140.0" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="Tag 1:" />
                                <ComboBox fx:id="tagTypeOneComboBox" prefWidth="140.0" />
                                <TextField fx:id="tagValueOneField" promptText="Value" />
                            </children>
                        </HBox>
                        <VBox fx:id="secondTagBox" spacing="10">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label text="Tag 2:" />
                                        <ComboBox fx:id="tagTypeTwoComboBox" prefWidth="140.0" />
                                        <TextField fx:id="tagValueTwoField" promptText="Value" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <Button onAction="#handleSearch" text="Search" />
                        <Button onAction="#handleCreateAlbumFromResults" text="Create Album From Results" />
                        <Button onAction="#handleBack" text="Back" />
                    </children>
                </HBox>
                <Label fx:id="resultsLabel" text="Results: 0" />
                <ListView fx:id="resultsListView" prefHeight="360.0" prefWidth="520.0" />
            </children>
        </VBox>
    </center>
</BorderPane>
