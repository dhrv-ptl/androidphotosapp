<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.CreateAlbumFromSearchDialogController"
      alignment="CENTER"
      spacing="12">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
    <children>
        <Label text="Create Album From Search" />
        <TextField fx:id="albumNameField" promptText="Album Name" />
        <HBox alignment="CENTER" spacing="10">
            <children>
                <Button onAction="#handleCreate" text="Create" />
                <Button onAction="#handleCancel" text="Cancel" />
            </children>
        </HBox>
    </children>
</VBox>
