<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AlbumController">
    <center>
        <HBox spacing="16">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <children>
                <VBox spacing="12">
                    <children>
                        <Label text="Album Screen" />
                        <Label fx:id="albumLabel" text="Album" />
                        <ListView fx:id="photoListView" prefHeight="420.0" prefWidth="320.0" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Button onAction="#handleAddPhoto" text="Add Photo" />
                                <Button onAction="#handleRemovePhoto" text="Remove Photo" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox spacing="12">
                    <children>
                        <ImageView fx:id="previewImageView" fitHeight="320.0" fitWidth="420.0" pickOnBounds="true" preserveRatio="true" />
                        <Label fx:id="captionLabel" text="Caption:" wrapText="true" />
                        <Label fx:id="pathLabel" text="Path:" wrapText="true" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Button onAction="#handlePreviousPhoto" text="Previous" />
                                <Button onAction="#handleNextPhoto" text="Next" />
                                <Button onAction="#handleRecaptionPhoto" text="Recaption" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Button onAction="#handleCopyPhoto" text="Copy To Album" />
                                <Button onAction="#handleMovePhoto" text="Move To Album" />
                                <Button onAction="#handleBack" text="Back" />
                            </children>
                        </HBox>
                    </children>
                    <HBox.hgrow>
                        <Priority fx:constant="ALWAYS" />
                    </HBox.hgrow>
                </VBox>
            </children>
        </HBox>
    </center>
</BorderPane>
