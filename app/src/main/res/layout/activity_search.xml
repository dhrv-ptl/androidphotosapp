<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/text_search_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/search_photos"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/search_mode_label" />

    <Spinner
        android:id="@+id/spinner_search_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/first_criteria_label"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinner_first_tag_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <AutoCompleteTextView
        android:id="@+id/input_first_tag_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/search_value_hint"
        android:inputType="text" />

    <LinearLayout
        android:id="@+id/layout_second_criteria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/second_criteria_label"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinner_second_tag_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <AutoCompleteTextView
            android:id="@+id/input_second_tag_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/search_value_hint"
            android:inputType="text" />
    </LinearLayout>

    <Button
        android:id="@+id/button_run_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/run_search" />

    <TextView
        android:id="@+id/text_empty_results"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:text="@string/no_search_results"
        android:visibility="gone" />

    <ListView
        android:id="@+id/list_search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:dividerHeight="1dp" />

</LinearLayout>
